# ===== Kubernetes 部署配置 =====
K8S_NAMESPACE=default
K8S_REPLICAS=3
K8S_CPU_LIMIT=1000m
K8S_MEMORY_LIMIT=1Gi
K8S_CPU_REQUEST=500m
K8S_MEMORY_REQUEST=512Mi

# ===== Docker 配置 =====
DOCKER_REGISTRY=registry.example.com
DOCKER_IMAGE_TAG=v4.0
DOCKER_PULL_POLICY=IfNotPresent
