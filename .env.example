# Stock-WebAgent 環境配置示例
# 複製此文件為 .env 並填入實際值

# ===== Groq API 配置 =====
MAIAGENT_API_KEY=your_groq_api_key_here
MAIAGENT_CHATBOT_ID=your_chatbot_id_here

# ===== Supabase 配置 =====
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# ===== Redis 配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=stock_redis_pwd
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ===== PostgreSQL 配置 (可選) =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=stock_password
POSTGRES_DB=stock_db

# ===== FastAPI 配置 =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# ===== GraphQL 配置 =====
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=false

# ===== 機器學習配置 =====
ML_MODEL_PATH=./models
ML_FEATURE_CACHE_SIZE=1000
ML_PCA_COMPONENTS=10

# ===== 緩存配置 =====
CACHE_TYPE=redis  # 或 memory
CACHE_TTL_KLINE=86400  # 24 小時
CACHE_TTL_SENTIMENT=3600  # 1 小時
CACHE_TTL_ANALYSIS=1800  # 30 分鐘
CACHE_TTL_MACRO=300  # 5 分鐘

# ===== 任務隊列配置 =====
TASK_QUEUE_WORKERS=10
TASK_MAX_RETRIES=3
TASK_TIMEOUT=300  # 秒

# ===== WebSocket 配置 =====
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10
WEBSOCKET_MAX_CONNECTIONS=1000

# ===== 系統配置 =====
TZ=Asia/Taipei
ENVIRONMENT=development  # development, staging, production
DEBUG=false

# ===== 監控和日誌 =====
ENABLE_METRICS=true
METRICS_PORT=8001
LOG_FORMAT=json  # json 或 text
<<<<<<< Updated upstream
